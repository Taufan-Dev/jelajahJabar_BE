		{
			"name": "4. Pemesanan Tiket & Pembayaran",
			"item": [
				{
					"name": "Pesan Tiket (Create Transaksi)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"wisata_id\": 1,\n    \"jumlah_tiket\": 2,\n    \"tanggal_kunjungan\": \"2026-06-25\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/tiket",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tiket"
							]
						},
						"description": "Membuat order tiket baru. Response akan mengembalikan detail transaksi beserta `snap_token` Midtrans untuk pembayaran di webview/client."
					},
					"response": []
				},
				{
					"name": "Riwayat Tiket User",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/tiket",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tiket"
							]
						}
					},
					"response": []
				},
				{
					"name": "Simulasi Webhook Callback Midtrans",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"order_id\": \"TKT-1716123456\", \n    \"transaction_status\": \"settlement\",\n    \"gross_amount\": \"80000.00\",\n    \"payment_type\": \"qris\",\n    \"signature_key\": \"SESUAIKAN_SIGNATURE_KEY_JIKA_VALIDASI_AKTIF\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/payment/callback",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payment",
								"callback"
							]
						},
						"description": "Menguji webhook penerimaan notifikasi Midtrans. Silakan ganti order_id dengan ID tiket real berstatus pending untuk simulasi sukses pembayaran (settlement)."
					},
					"response": []
				},
				{
					"name": "Simulasi Callback Cepat (Tanpa Midtrans SDK)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"kode_tiket\": \"TIK-XXXXXX\",\n    \"status\": \"settlement\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/payment/simulate-callback",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"payment",
								"simulate-callback"
							]
						},
						"description": "Mensimulasikan pembayaran tiket secara lokal secara cepat tanpa memerlukan payload Midtrans SDK asli. Status bisa diisi: settlement (sukses), pending, failed."
					},
					"response": []
				},
				{
					"name": "Get Tiket QR Code (SVG)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "image/svg+xml",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/tiket/TIK-XXXXXX/qrcode",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"tiket",
								"TIK-XXXXXX",
								"qrcode"
							]
						},
						"description": "Mengambil gambar QR Code tiket secara langsung sebagai SVG untuk mempermudah render di aplikasi Android atau browser."
					},
					"response": []
				}
			]
		},
		{
			"name": "5. Rekomendasi & Ulasan",
			"item": [
